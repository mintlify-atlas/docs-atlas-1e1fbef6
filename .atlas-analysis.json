  "keyFeatures": [
    "Multi-session agent grid with real-time priority ranking (CRITICAL / HIGH / MEDIUM / LOW)",
    "Full xterm.js terminal overlay with PTY streaming over Socket.IO",
    "Activity sidebar with cross-project alerts and priority queue",
    "Automatic project discovery from local git repos and GitHub account",
    "Git worktree isolation — each session gets its own branch and working tree",
    "AI orchestrator for session summaries, diff tracking, and PR creation",
    "Safe mode: loopback-only binding, CORS restriction, and protected-agent approvals",
    "Auto-respond and coordination features for hands-free session management",
    "Mobile support with swipe gestures and touch controls"
  ],
  "publicApiSurface": [
